{
  "name": "taquin",
  "version": "1.0.0",
  "description": "Puzzle 15 — juego Taquin implementado con TypeScript, Web Components y Tailwind CSS",
  "scripts": {
    "build:css": "tailwindcss -i src/css/main.css -o dist/css/main.css",
    "build:css:watch": "tailwindcss -i src/css/main.css -o dist/css/main.css --watch",
    "build:ts": "tsc",
    "build:ts:watch": "tsc --watch",
    "build": "npm run build:css && npm run build:ts",
    "dev": "concurrently \"npm run build:css:watch\" \"npm run build:ts:watch\" \"live-server --port=3000 --watch=dist/\"",
    "lint": "eslint 'src/ts/**/*.ts'",
    "lint:fix": "eslint 'src/ts/**/*.ts' --fix",
    "format": "prettier --write \"src/**/*.{ts,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css,html}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "live-server": "^1.2.2",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.0"
  }
}
